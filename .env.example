# Environment Variables Documentation
# DO NOT ADD REAL SECRETS IN THIS FILE!

# OpenAI API Key for generating AI feedback
OPENAI_API_KEY=your_openai_api_key_here

# Cloudflare Turnstile Secret Key (Backend verification)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Upstash Redis Keys for Rate Limiting
# Leave empty or comment out to bypass rate limit
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# (Optional) Cloudflare Turnstile Site Key for Frontend (if you switch to dynamic env configuration)
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
